{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c \"python -m riskweave_api.ingestion.pipeline_cli diagnose --snapshot-id 3\"",
    "restartPolicyType": "NEVER",
    "numReplicas": 1
  }
}
