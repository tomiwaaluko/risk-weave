{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile"
  },
  "deploy": {
    "startCommand": "sh -c \"python -m riskweave_api.ingestion.cli --snapshot demo-freeze-candidate-1 --universe /app/data/universe/entities.json\"",
    "restartPolicyType": "NEVER",
    "numReplicas": 1
  }
}
