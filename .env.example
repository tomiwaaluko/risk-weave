# Copy this file to .env before running Docker Compose.
# These development-only values are intentionally non-secret placeholders.

# The default hostnames below (postgres/neo4j/redis) target the local Docker
# Compose stack. To point a local shell at the Railway cloud databases instead
# (ADR-008), copy the reference-variable values from the Railway service (never
# commit real credentials) into the commented alternates. See
# docs/solutions/architecture-patterns/railway-primary-host.md.

# PostgreSQL (server-side only)
POSTGRES_DB=riskweave
POSTGRES_USER=riskweave
POSTGRES_PASSWORD=change-me-for-local-development
DATABASE_URL=postgresql://riskweave:change-me-for-local-development@postgres:5432/riskweave
# Railway alternate (from the Postgres service's DATABASE_URL reference variable):
# DATABASE_URL=postgresql://postgres:<password>@<host>.railway.internal:5432/railway

# Neo4j (server-side only; password must be at least 8 characters)
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-for-local-development
NEO4J_URI=bolt://neo4j:7687
# Railway alternate (Neo4j Docker service; use neo4j+s://<public-domain> from
# outside Railway, or bolt://<service>.railway.internal:7687 within the project):
# NEO4J_URI=bolt://neo4j.railway.internal:7687

# Redis (server-side only)
REDIS_URL=redis://redis:6379/0
# Railway alternate (from the Redis service's REDIS_URL reference variable):
# REDIS_URL=redis://default:<password>@<host>.railway.internal:6379

# Gemini (server-side only; never prefix this variable with NEXT_PUBLIC_)
GEMINI_API_KEY=replace-with-a-real-server-side-key
FRED_API_KEY=replace-with-a-real-server-side-key
SEC_USER_AGENT=RiskWeave contact@example.com

# Service configuration
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Frontend (client-visible; set as a Vercel project env var — never put secrets here)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Backend CORS allowlist for the Vercel production + preview domains
CORS_ALLOW_ORIGIN_REGEX=^https://riskweave.*\.vercel\.app$|^http://localhost:3000$
