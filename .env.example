# Copy this file to .env before running Docker Compose.
# These development-only values are intentionally non-secret placeholders.

# The default hostnames below (postgres/neo4j/redis) target the local Docker
# Compose stack. To point a local shell at the Railway cloud databases instead
# (ADR-008), copy the reference-variable values from the Railway service (never
# commit real credentials) into the commented alternates. See
# docs/solutions/architecture-patterns/railway-primary-host.md.

# PostgreSQL (server-side only)
POSTGRES_DB=riskweave
POSTGRES_USER=riskweave
POSTGRES_PASSWORD=change-me-for-local-development
DATABASE_URL=postgresql://riskweave:change-me-for-local-development@postgres:5432/riskweave
# Railway alternate (from the Postgres service's DATABASE_URL reference variable):
# DATABASE_URL=postgresql://postgres:<password>@<host>.railway.internal:5432/railway

# Neo4j (server-side only; password must be at least 8 characters)
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-for-local-development
NEO4J_URI=bolt://neo4j:7687
# Railway alternate (Neo4j Docker service; use neo4j+s://<public-domain> from
# outside Railway, or bolt://<service>.railway.internal:7687 within the project):
# NEO4J_URI=bolt://neo4j.railway.internal:7687

# Redis (server-side only)
REDIS_URL=redis://redis:6379/0
# Railway alternate (from the Redis service's REDIS_URL reference variable):
# REDIS_URL=redis://default:<password>@<host>.railway.internal:6379

# Gemini (server-side only; never prefix this variable with NEXT_PUBLIC_)
GEMINI_API_KEY=replace-with-a-real-server-side-key
FRED_API_KEY=replace-with-a-real-server-side-key
SEC_USER_AGENT=RiskWeave contact@example.com

# RIS-31 / ADR-010: shared bearer key gating mutating and Gemini-calling
# backend endpoints. Unset leaves the API open (local dev, CI, Compose);
# Railway production must set this to a real generated secret. The frontend's
# server-side proxy (frontend/src/app/api/backend) reads the same value —
# never prefix it with NEXT_PUBLIC_ and never put it in a client component.
RISKWEAVE_API_KEY=replace-with-a-real-server-side-key
RATE_LIMIT_ENABLED=true

# RIS-34: provider cost/quota accounting. Gemini budget thresholds are USD/day;
# the soft threshold only warns, the hard threshold pauses (resumable) batch
# extraction. SEC/FRED limits are the documented fair-use ceilings the
# ingestion pipeline asserts its measured request counts against.
# GEMINI_DAILY_SOFT_BUDGET_USD=5.0
# GEMINI_DAILY_HARD_BUDGET_USD=20.0
# SEC_FAIR_USE_REQUESTS_PER_SECOND=10
# FRED_RATE_LIMIT_REQUESTS_PER_MINUTE=120

# Service configuration
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Scenario/run/graph-snapshot storage backend (RIS-30): "memory" (default,
# used by tests and offline demos without a live Postgres) or "postgres"
# (persists across restarts; requires `alembic upgrade head`). docker-compose
# sets this to "postgres" directly for the backend service since a real
# Postgres is always available there; Railway sets it via a service variable.
# SCENARIO_STORE_BACKEND=memory

# Frontend (client-visible; set as a Vercel project env var — never put secrets here)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Backend CORS allowlist for the Vercel production + preview domains
CORS_ALLOW_ORIGIN_REGEX=^https://risk-weave[a-z0-9-]*\.vercel\.app$|^http://localhost:3000$

# RIS-31 / ADR-010: off by default so the superseded RIS-15 Cytoscape.js spike
# page (frontend/src/app/spike) is absent from a default production build.
ENABLE_SPIKE_PAGE=false

# RIS-33: structured JSON log verbosity (DEBUG/INFO/WARNING/ERROR). Defaults
# to INFO; see docs/ops/observability-runbook.md.
# LOG_LEVEL=INFO
