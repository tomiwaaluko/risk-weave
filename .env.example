# Copy this file to .env before running Docker Compose.
# These development-only values are intentionally non-secret placeholders.

# PostgreSQL (server-side only)
POSTGRES_DB=riskweave
POSTGRES_USER=riskweave
POSTGRES_PASSWORD=change-me-for-local-development
DATABASE_URL=postgresql://riskweave:change-me-for-local-development@postgres:5432/riskweave

# Neo4j (server-side only; password must be at least 8 characters)
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-for-local-development
NEO4J_URI=bolt://neo4j:7687

# Redis (server-side only)
REDIS_URL=redis://redis:6379/0

# Gemini (server-side only; never prefix this variable with NEXT_PUBLIC_)
GEMINI_API_KEY=replace-with-a-real-server-side-key

# Service configuration
BACKEND_PORT=8000
FRONTEND_PORT=3000
